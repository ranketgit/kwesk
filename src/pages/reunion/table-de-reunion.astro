---
// pages/reunion/tables.astro
import Layout from '../../layouts/Layout.astro';
import AmCTA from '../../components/AmCTA.astro';

const images = [
  "/reunion/mt1.jpg",
  "/reunion/mt2.jpg",
  "/reunion/mt3.jpg",
  "/reunion/mt-hero.jpg"
];

const rectangularSizes = [
  { cap: "6 personnes",  length: "180 cm", width: "90 cm",  area: "1,62 m²", ideal: "Petites équipes, réunions rapides" },
  { cap: "8 personnes",  length: "240 cm", width: "120 cm", area: "2,88 m²", ideal: "Équipes standard" },
  { cap: "10 personnes", length: "280 cm", width: "120 cm", area: "3,36 m²", ideal: "Groupes mixtes, formations" },
  { cap: "12 personnes", length: "320 cm", width: "120 cm", area: "3,84 m²", ideal: "Conseils d'administration" },
];

const roundSizes = [
  { cap: "6 personnes",  diam: "Ø 150 cm", area: "1,77 m²", ideal: "Brainstorming, discussions" },
  { cap: "10 personnes", diam: "Ø 190 cm", area: "2,84 m²", ideal: "Séminaires, formations" },
];
---

<Layout
  title="Tables de Réunion 6-12 Personnes | Maroc – KWESK"
  description="Tables réunion rectangulaires & rondes, 6 à 12 personnes. Dimensions, matériaux professionnels. Certifiées. Prix devis. Livraison Maroc."
>
  <section class="relative h-[90vh] min-h-[600px] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <img src={images[3]} alt="Tables de Réunion Professionnelles" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-stone-900/90 via-stone-900/70 to-stone-900/40"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-16">
      <div class="max-w-3xl">
        <a href="/salles-reunion" class="inline-flex items-center gap-2 text-[#8b8b4b] text-sm mb-6 hover:underline">
          ← Retour aux Salles de Réunion
        </a>
        <span class="inline-block text-xs tracking-[4px] text-[#8b8b4b] mb-4 uppercase">ESPACES DE COLLABORATION</span>
        <h1 class="text-4xl lg:text-5xl font-bold text-white leading-tight mb-6">Tables de Réunion Professionnelles au Maroc | 6 à 12 Personnes</h1>
        <p class="text-lg text-stone-300 leading-relaxed mb-8">Design professionnel et élégant pour vos espaces de collaboration. Tables de réunion pour 6 à 12 personnes, idéales pour salles de réunion, open spaces et bureaux collaboratifs.</p>
        <div class="flex flex-wrap gap-4">
          <a href="/contact" class="px-8 py-4 bg-[#8b8b4b] text-white text-sm font-semibold uppercase tracking-wider hover:bg-white hover:text-stone-900 transition-all">Demander un Devis Gratuit</a>
          <a href="#product" class="px-8 py-4 bg-transparent border border-white/30 text-white text-sm font-semibold uppercase tracking-wider hover:bg-white hover:text-stone-900 transition-all">Découvrir</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-stone-900 py-8">
    <div class="max-w-7xl mx-auto px-6 lg:px-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <span class="block text-2xl lg:text-3xl font-bold text-[#8b8b4b] mb-2">6-14 Pers</span>
          <span class="text-xs text-stone-400 uppercase tracking-wider">Capacité</span>
        </div>
        <div>
          <span class="block text-2xl lg:text-3xl font-bold text-[#8b8b4b] mb-2">25 mm</span>
          <span class="text-xs text-stone-400 uppercase tracking-wider">Épaisseur Plateau</span>
        </div>
        <div>
          <span class="block text-2xl lg:text-3xl font-bold text-[#8b8b4b] mb-2">5 Ans</span>
          <span class="text-xs text-stone-400 uppercase tracking-wider">Garantie</span>
        </div>
        <div>
          <span class="block text-2xl lg:text-3xl font-bold text-[#8b8b4b] mb-2">ISO/EN</span>
          <span class="text-xs text-stone-400 uppercase tracking-wider">Certifié BIFMA</span>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white" id="product">
    <div class="max-w-7xl mx-auto px-6 lg:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <div class="flex flex-col gap-6">
          <div class="relative bg-stone-50 border border-stone-200 aspect-[4/3] flex items-center justify-center overflow-hidden group">
            <button id="prevBtn" class="absolute left-4 z-10 w-10 h-10 bg-white/80 hover:bg-[#8b8b4b] hover:text-white flex items-center justify-center rounded-full shadow-sm transition-all opacity-0 group-hover:opacity-100" aria-label="Previous">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            
            <img id="mainImage" src={images[0]} alt="Table de Réunion Rectangulaire" class="w-full h-full object-cover transition-opacity duration-300" />
            
            <button id="nextBtn" class="absolute right-4 z-10 w-10 h-10 bg-white/80 hover:bg-[#8b8b4b] hover:text-white flex items-center justify-center rounded-full shadow-sm transition-all opacity-0 group-hover:opacity-100" aria-label="Next">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          </div>
          
          <div class="grid grid-cols-4 gap-4">
            {images.map((img, i) => (
              <button 
                class={`thumb-btn aspect-square border bg-stone-50 flex items-center justify-center p-1 transition-all hover:border-[#8b8b4b] ${i === 0 ? 'border-[#8b8b4b]' : 'border-stone-200'}`}
                data-index={i}
              >
                <img src={img} alt={`Vue ${i+1}`} class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        </div>

        <div class="flex flex-col justify-center">
          <span class="inline-block text-xs tracking-[3px] text-[#8b8b4b] mb-4 uppercase">GAMME PROFESSIONNELLE</span>
          <h2 class="text-3xl lg:text-4xl font-bold text-stone-900 mb-6">Tables de Réunion</h2>
          
          <p class="text-stone-600 leading-relaxed mb-8 border-l-4 border-[#1c1917] pl-6">
            Table de réunion pour 6 à 12 personnes selon dimensions choisies. Le plateau en mélaminé épaisseur 25mm offre une surface de travail adaptée aux réunions professionnelles. Structure métallique assure stabilité. Passe-câbles central intégré facilite connexion équipements.
          </p>

          <div class="mb-10">
            <h3 class="text-sm font-bold text-stone-900 uppercase tracking-wider mb-4 border-b border-stone-200 pb-2">Formats Disponibles</h3>
            <div class="space-y-3">
              <div class="flex justify-between items-center group cursor-default p-3 border border-stone-200 hover:border-[#8b8b4b] transition-all">
                <div>
                  <span class="block font-bold text-stone-900">Rectangulaire</span>
                  <span class="text-sm text-stone-500">Pour réunions structurées (6-14 pers)</span>
                </div>
                <span class="text-[#8b8b4b]">Standard</span>
              </div>
              <div class="flex justify-between items-center group cursor-default p-3 border border-stone-200 hover:border-[#8b8b4b] transition-all">
                <div>
                  <span class="block font-bold text-stone-900">Ronde / Ovale</span>
                  <span class="text-sm text-stone-500">Pour échanges égalitaires (3-7 pers)</span>
                </div>
                <span class="text-[#8b8b4b]">Collaboratif</span>
              </div>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact" class="px-8 py-4 bg-[#1c1917] text-white text-sm font-semibold uppercase tracking-wider hover:bg-[#8b8b4b] transition-all text-center">
              Demander un Devis
            </a>
            <div class="flex items-center justify-center gap-2 text-sm text-stone-500">
              <span class="w-2 h-2 rounded-full bg-green-500"></span>
              En stock
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="py-20 bg-stone-50">
    <div class="max-w-7xl mx-auto px-6 lg:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div>
          <h3 class="text-xl font-bold text-stone-900 mb-4 uppercase">Table Rectangulaire</h3>
          <p class="text-sm text-stone-600 leading-relaxed mb-4">Pour 6 à 12 personnes. Répond aux besoins de la majorité des salles de réunion professionnelles. Format rectangulaire permet installation le long des murs ou au centre de salle.</p>
          <ul class="text-sm text-stone-600 space-y-2">
            <li>• Passe-câbles central intégré</li>
            <li>• Structure métallique stable</li>
            <li>• Dimensions standard: 240x120 cm</li>
          </ul>
        </div>

        <div>
          <h3 class="text-xl font-bold text-stone-900 mb-4 uppercase">Table Ronde</h3>
          <p class="text-sm text-stone-600 leading-relaxed mb-4">Favorisant les échanges égalitaires. Parfaite pour les réunions créatives et les brainstormings. Crée une dynamique collaborative sans hiérarchie spatiale.</p>
          <ul class="text-sm text-stone-600 space-y-2">
            <li>• Pied central en acier</li>
            <li>• Diamètre 100 à 160 cm</li>
            <li>• Option prise électrique centrale</li>
          </ul>
        </div>

        <div>
          <h3 class="text-xl font-bold text-stone-900 mb-4 uppercase">Table Ovale</h3>
          <p class="text-sm text-stone-600 leading-relaxed mb-4">Combine avantages du format rectangulaire et de la table ronde. Offre capacité d'accueil du rectangulaire avec dynamique collaborative de la ronde. Convient particulièrement aux salles de réunion direction.</p>
          <ul class="text-sm text-stone-600 space-y-2">
            <li>• Adoucit les angles</li>
            <li>• Efficacité spatiale</li>
            <li>• Design élégant</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-stone-900 text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-16">
      <div class="text-center mb-16">
        <span class="inline-block text-xs tracking-[3px] text-[#8b8b4b] mb-4 uppercase">DIMENSIONS</span>
        <h2 class="text-3xl lg:text-4xl font-bold mb-4">Guide des Dimensions par Capacité</h2>
        <p class="text-stone-400 max-w-2xl mx-auto">Chaque participant a besoin de 60 à 70 cm de largeur. Dimensions hors tout — prévoir 1 m de dégagement autour de la table.</p>
      </div>

      <div class="space-y-16">
        <div>
          <h3 class="text-lg font-bold text-[#8b8b4b] uppercase mb-6 border-b border-stone-700 pb-2">Format Rectangulaire</h3>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-stone-700">
                  <th class="text-left py-3 pr-6 text-stone-400 font-semibold uppercase tracking-wider">Capacité</th>
                  <th class="text-left py-3 pr-6 text-stone-400 font-semibold uppercase tracking-wider">Longueur</th>
                  <th class="text-left py-3 pr-6 text-stone-400 font-semibold uppercase tracking-wider">Largeur</th>
                  <th class="text-left py-3 pr-6 text-stone-400 font-semibold uppercase tracking-wider">Surface</th>
                  <th class="text-left py-3 text-stone-400 font-semibold uppercase tracking-wider">Idéal pour</th>
                </tr>
              </thead>
              <tbody>
                {rectangularSizes.map((item) => (
                  <tr class="border-b border-stone-800 hover:bg-stone-800 transition-colors">
                    <td class="py-4 pr-6 font-bold text-white">{item.cap}</td>
                    <td class="py-4 pr-6 text-[#8b8b4b] font-semibold">{item.length}</td>
                    <td class="py-4 pr-6 text-[#8b8b4b] font-semibold">{item.width}</td>
                    <td class="py-4 pr-6 text-stone-400">{item.area}</td>
                    <td class="py-4 text-stone-400">{item.ideal}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <div>
          <h3 class="text-lg font-bold text-[#8b8b4b] uppercase mb-6 border-b border-stone-700 pb-2">Format Ronde</h3>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-stone-700">
                  <th class="text-left py-3 pr-6 text-stone-400 font-semibold uppercase tracking-wider">Capacité</th>
                  <th class="text-left py-3 pr-6 text-stone-400 font-semibold uppercase tracking-wider">Diamètre</th>
                  <th class="text-left py-3 pr-6 text-stone-400 font-semibold uppercase tracking-wider">Surface</th>
                  <th class="text-left py-3 text-stone-400 font-semibold uppercase tracking-wider">Idéal pour</th>
                </tr>
              </thead>
              <tbody>
                {roundSizes.map((item) => (
                  <tr class="border-b border-stone-800 hover:bg-stone-800 transition-colors">
                    <td class="py-4 pr-6 font-bold text-white">{item.cap}</td>
                    <td class="py-4 pr-6 text-[#8b8b4b] font-semibold">{item.diam}</td>
                    <td class="py-4 pr-6 text-stone-400">{item.area}</td>
                    <td class="py-4 text-stone-400">{item.ideal}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Comment Choisir -->
  <section class="py-20 bg-white border-t border-stone-200">
    <div class="max-w-5xl mx-auto px-6 lg:px-16">
      <h2 class="text-3xl lg:text-4xl font-bold text-stone-900 mb-4 text-center">Comment Choisir la Bonne Taille ?</h2>
      <p class="text-stone-500 text-center mb-12 max-w-2xl mx-auto">Chaque participant a besoin de 60 à 70 cm de largeur et 40 à 50 cm de profondeur. Suivez ces étapes pour choisir la bonne dimension.</p>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="space-y-6">
          <div class="flex gap-4 items-start">
            <span class="w-8 h-8 bg-[#8b8b4b] text-white font-bold flex items-center justify-center flex-shrink-0 text-sm">1</span>
            <div>
              <h3 class="font-bold text-stone-900 mb-1">Mesurez votre salle</h3>
              <p class="text-sm text-stone-600">Notez la longueur et la largeur disponibles. Soustrayez 2 m (1 m de chaque côté) pour l'espace de circulation autour de la table.</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <span class="w-8 h-8 bg-[#8b8b4b] text-white font-bold flex items-center justify-center flex-shrink-0 text-sm">2</span>
            <div>
              <h3 class="font-bold text-stone-900 mb-1">Calculez la longueur minimale</h3>
              <p class="text-sm text-stone-600">Multipliez le nombre de participants par 65 cm. Exemple : 8 personnes × 65 cm = 520 cm ÷ 2 côtés = 260 cm minimum.</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <span class="w-8 h-8 bg-[#8b8b4b] text-white font-bold flex items-center justify-center flex-shrink-0 text-sm">3</span>
            <div>
              <h3 class="font-bold text-stone-900 mb-1">Choisissez la forme adaptée</h3>
              <p class="text-sm text-stone-600">Rectangulaire pour réunions structurées. Ronde pour brainstormings et discussions créatives. Ovale pour un équilibre des deux.</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <span class="w-8 h-8 bg-[#8b8b4b] text-white font-bold flex items-center justify-center flex-shrink-0 text-sm">4</span>
            <div>
              <h3 class="font-bold text-stone-900 mb-1">Consultez nos experts</h3>
              <p class="text-sm text-stone-600">Notre équipe réalise gratuitement un plan d'<a href="/amenagement-de-bureau" class="text-[#8b8b4b] font-bold hover:underline">aménagement complet de bureau</a> incluant votre salle de réunion. <a href="/salles-reunion" class="text-[#8b8b4b] font-bold hover:underline">Découvrez nos solutions salles de réunion.</a></p>
            </div>
          </div>
        </div>

        <div class="bg-stone-50 border border-stone-200 p-8">
          <h3 class="font-bold text-stone-900 mb-6 text-lg">Exemples Pratiques</h3>
          <div class="space-y-5">
            <div class="border-b border-stone-200 pb-4">
              <p class="font-bold text-stone-900 text-sm mb-1">Équipe de 6 personnes</p>
              <p class="text-sm text-stone-600">→ Table rectangulaire <strong>180 × 90 cm</strong> minimum. Format ronde Ø 150 cm pour brainstormings.</p>
            </div>
            <div class="border-b border-stone-200 pb-4">
              <p class="font-bold text-stone-900 text-sm mb-1">Conseil d'administration de 12 personnes</p>
              <p class="text-sm text-stone-600">→ Table rectangulaire <strong>320 × 120 cm</strong> recommandée. Salle minimum 520 × 320 cm.</p>
            </div>
            <div>
              <p class="font-bold text-stone-900 text-sm mb-1">Espace polyvalent (formations + réunions)</p>
              <p class="text-sm text-stone-600">→ Table ronde <strong>Ø 190 cm</strong> pour 10 personnes. Adaptable à différentes configurations.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="grid grid-cols-1 lg:grid-cols-2 min-h-[600px]">
    <div class="flex flex-col justify-center p-12 lg:p-20 bg-white order-2 lg:order-1">
      <span class="inline-block text-xs tracking-[3px] text-[#8b8b4b] mb-4 uppercase">QUALITÉ</span>
      <h2 class="text-3xl font-bold text-stone-900 mb-6">Caract&eacute;ristiques Techniques</h2>
      <p class="text-stone-600 leading-relaxed mb-8">Design professionnel et élégant caractérisant nos tables de réunion.</p>
      
      <div class="space-y-6">
        <div class="border-l-4 border-[#8b8b4b] pl-6">
          <h3 class="font-bold text-stone-900 mb-2">Plateau Mélaminé 25mm</h3>
          <p class="text-sm text-stone-600">Offre rigidité nécessaire pour grandes dimensions sans affaissement. Surface résistante à usage professionnel intensif.</p>
        </div>
        <div class="border-l-4 border-[#8b8b4b] pl-6">
          <h3 class="font-bold text-stone-900 mb-2">Structure Métallique</h3>
          <p class="text-sm text-stone-600">Garantit maintien stable même pour grandes dimensions de 240-320 cm. Supporte poids du plateau et équipements.</p>
        </div>
        <div class="border-l-4 border-[#8b8b4b] pl-6">
          <h3 class="font-bold text-stone-900 mb-2">Passe-Câbles Intégré</h3>
          <p class="text-sm text-stone-600">Central intégré dans tables rectangulaires. Permet passage discret des câbles électriques et réseau.</p>
        </div>
        <div class="border-l-4 border-[#8b8b4b] pl-6">
          <h3 class="font-bold text-stone-900 mb-2">Options de Personnalisation</h3>
          <p class="text-sm text-stone-600">Plateau en verre trempé, boîtier de connectique, pieds chromés pour une finition haut de gamme.</p>
        </div>
      </div>
    </div>
    <div class="relative overflow-hidden order-1 lg:order-2">
      <img src={images[2]} alt="Détails Table de Réunion" class="w-full h-full object-cover" />
    </div>
  </section>

  <section class="py-20 bg-stone-50">
    <div class="max-w-7xl mx-auto px-6 lg:px-16">
      <div class="text-center mb-16">
        <span class="inline-block text-xs tracking-[3px] text-[#8b8b4b] mb-4 uppercase">APPLICATIONS</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-stone-900 mb-4">Pour Tous Vos Espaces</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white p-8 border border-stone-200">
          <h3 class="text-xl font-bold text-stone-900 mb-2">Salles de Direction</h3>
          <p class="text-sm text-stone-600">Format rectangulaire 280-320 cm pour conseils d'administration. Option plateau verre et pieds chromés pour le prestige.</p>
        </div>
        <div class="bg-white p-8 border border-stone-200">
          <h3 class="text-xl font-bold text-stone-900 mb-2">Open Spaces</h3>
          <p class="text-sm text-stone-600">Format rectangulaire 200-240 cm permet réunions d'équipe sans monopoliser espace. S'harmonise avec mobilier bureau moderne.</p>
        </div>
        <div class="bg-white p-8 border border-stone-200">
          <h3 class="text-xl font-bold text-stone-900 mb-2">Bureaux Collaboratifs</h3>
          <p class="text-sm text-stone-600">Format ronde favorise échanges informels et brainstormings créatifs. Dimensions modulables.</p>
        </div>
        <div class="bg-white p-8 border border-stone-200">
          <h3 class="text-xl font-bold text-stone-900 mb-2">Conférences</h3>
          <p class="text-sm text-stone-600">Pour présentations et formations. Structure stable supporte matériel audiovisuel.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white border-t border-stone-200">
    <div class="max-w-7xl mx-auto px-6 lg:px-16 text-center">
      <h2 class="text-2xl font-bold text-stone-900 mb-12">Aménagement Complet de Salle de Réunion</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/chaises" class="group bg-stone-50 p-8 border border-stone-200 hover:border-[#8b8b4b] transition-all hover:-translate-y-1">
          <h3 class="text-xl font-bold text-stone-900 mb-3 group-hover:text-[#8b8b4b] transition-colors">Chaises Professionnelles</h3>
          <p class="text-sm text-stone-600 leading-relaxed mb-4">Gamme complète de chaises certifiées BIFMA et EN 1335 pour salles de réunion.</p>
          <span class="text-[#8b8b4b] text-sm font-semibold uppercase tracking-wider">Voir les chaises →</span>
        </a>

        <a href="/reunion/rangement/armoire-basse" class="group bg-stone-50 p-8 border border-stone-200 hover:border-[#8b8b4b] transition-all hover:-translate-y-1">
          <h3 class="text-xl font-bold text-stone-900 mb-3 group-hover:text-[#8b8b4b] transition-colors">Rangements</h3>
          <p class="text-sm text-stone-600 leading-relaxed mb-4">Armoire basse métallique et rangements muraux assortis.</p>
          <span class="text-[#8b8b4b] text-sm font-semibold uppercase tracking-wider">Voir les rangements →</span>
        </a>

        <a href="/salles-reunion" class="group bg-stone-50 p-8 border border-stone-200 hover:border-[#8b8b4b] transition-all hover:-translate-y-1">
          <h3 class="text-xl font-bold text-stone-900 mb-3 group-hover:text-[#8b8b4b] transition-colors">Solutions Salles de Réunion</h3>
