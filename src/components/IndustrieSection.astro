---
import ChairCard from './ChairCard.astro';
---

<section class="bg-white py-24 border-t border-stone-200">
  
  <div class="max-w-4xl mx-auto px-6 lg:px-16 text-center mb-20">
    <h2 class="text-3xl lg:text-5xl font-bold text-stone-900 mb-8">
      Mobilier Industriel et Rangement Professionnel
    </h2>
    <p class="text-stone-600 text-lg leading-relaxed text-justify">
      KWESK fabrique du <a href="/mobilier-industriel" class="text-[#8b8b4b] font-bold hover:text-stone-900 underline transition-colors">mobilier industriel professionnel</a> pour les environnements exigeants. Notre gamme comprend des tables de cantine robustes pour collectivités, des casiers vestiaires métalliques, des armoires de rangement et des solutions de stockage adaptées aux usines et établissements publics.
    </p>
  </div>

  <ChairCard
    title="Tables de Cantine pour Collectivités"
    description="Solutions robustes pour collectivités et environnements exigeants."
    image="/industrie/tables-cantine/1.jpg"
    versions={[{ name: "CANTINE PRO", type: "Table Collectivité" }]}
    imagePosition="right"
    href="/industrie/tables-cantine"
  />

  <ChairCard
    title="Casiers Vestiaires Métalliques"
    description="Casiers vestiaires métalliques adaptés aux usines et aux établissements publics."
    image="/industrie/casiers-vestiaire/1.webp"
    versions={[
      { name: "LOCKER 2", type: "Casier Double" },
      { name: "LOCKER 4", type: "Casier Quadruple" }
    ]}
    imagePosition="left"
    href="/industrie/casiers-vestiaire"
  />

  <ChairCard
    title="Armoires de Rangement et Stockage Industriel"
    description="Armoires de rangement et solutions de stockage industriel conçues pour résister à une utilisation intensive."
    image="/industrie/casiers-vestiaire/11.webp"
    versions={[{ name: "ATELIER PRO", type: "Armoire Industrielle" }]}
    imagePosition="right"
    href="/industrie/armoires-rangement"
  />

  <div class="text-center mt-20">
     <a href="/mobilier-industriel" class="inline-block px-8 py-4 bg-[#8b8b4b] text-white text-sm font-bold uppercase tracking-widest rounded-full hover:bg-stone-900 transition-all transform hover:scale-105">
        DÉCOUVRIR LE MOBILIER INDUSTRIEL →
     </a>
  </div>
</section>