---
interface Feature {
  title: string;
  description: string;
}

interface Props {
  features?: Feature[];
}

const { features = [
  {
    title: "Fabricant Marocain Depuis 2008",
    description: "KWESK conçoit et fabrique du mobilier bureau professionnel au Maroc depuis plus de 17 ans. Notre expertise de fabricant nous permet de maîtriser la qualité de chaque produit, du choix des matériaux à l'assemblage final."
  },
  {
    title: "Certifications Internationales BIFMA et EN 1335",
    description: "Nos chaises ergonomiques sont certifiées selon les normes BIFMA (Business and Institutional Furniture Manufacturers Association) et EN 1335, les références mondiales en matière de sécurité et de durabilité du mobilier de bureau."
  },
  {
    title: "Garantie 5 Ans et Service Après-Vente",
    description: "Chaque produit KWESK est livré avec une garantie de 5 ans. Notre service après-vente basé à Casablanca intervient rapidement pour toute maintenance ou remplacement de pièce."
  },
  {
    title: "Livraison et Installation sur Tout le Maroc",
    description: "Nous assurons la livraison et l'installation de votre mobilier professionnel dans tout le Royaume du Maroc  Casablanca, Rabat, Marrakech, Agadir, Tanger, Fès, Meknès, Oujda et plus encore. Notre équipe logistique prend en charge le transport, le montage et la mise en place dans vos locaux."
  }
]} = Astro.props;
---

<section class="features-section py-24 bg-[#1c1917]">
  <div class="max-w-7xl mx-auto px-8 lg:px-16">
    <h2 class="text-3xl lg:text-5xl text-center font-bold text-white mb-16">Pourquoi Choisir KWESK pour Votre Mobilier de Bureau au Maroc ?</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
      {features.map((feature, i) => (
        <div class="feature-item bg-[#292524] p-8 border-l-4 border-[#8b8b4b]" style={`--i: ${i}`}>
          <h3 class="feature-title text-xl font-bold text-white mb-4">{feature.title}</h3>
          <p class="feature-desc text-[#d6d3d1] leading-relaxed text-justify">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-item {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(var(--i) * 100ms);
  }

  .features-section.in-view .feature-item {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
        }
      });
    },
    { threshold: 0.2 }
  );

  document.querySelectorAll('.features-section').forEach((section) => {
    observer.observe(section);
  });
</script>